# Generated outputs - these contain question stems from past papers.
# Keep them OUT of public git for copyright safety. Run `igcse generate-paper`
# locally to regenerate any time.
output/*.pdf

# PDFs published via GitHub Pages live under simulator/public/papers/ and are
# tracked in git. They are auto-baked by `igcse build-simulator` from the
# latest output/*.pdf for each chapter set.

# Papers and chapter materials are the user's data, not source
# Excluded for copyright reasons (Cambridge IGCSE past papers are UCLES-copyrighted).
# Root-level only - keep `simulator/public/papers/` tracked for Pages distribution.
/papers/
/papers_working/
/chapters/


